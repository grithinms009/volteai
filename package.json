{
  "name": "anigravity-backend",
  "version": "1.0.0",
  "description": "AI-powered electricity bill analyzer backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "worker": "node src/workers/analysisWorker.js",
    "dev": "node --watch src/server.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset --force && node prisma/seed.js",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.13.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.1.0",
    "@fastify/static": "^7.0.1",
    "@prisma/client": "^5.10.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.1",
    "fastify-plugin": "^4.5.1",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.1",
    "ioredis": "^5.3.2",
    "ollama": "^0.5.0",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^22.3.0",
    "sharp": "^0.33.2",
    "tesseract.js": "^5.0.4",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "prisma": "^5.10.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
